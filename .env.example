# Supabase (Auth + DB + Storage)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
# Service role key (server-side only — used for admin operations like invite token validation)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# OpenAI (GPT-4.1 — primary LLM)
OPENAI_API_KEY=your_openai_key

# Deepgram (STT — cross-browser WebSocket streaming)
DEEPGRAM_API_KEY=your_deepgram_key
# Required for production: enables short-lived scoped keys instead of exposing main key
DEEPGRAM_PROJECT_ID=your_deepgram_project_id

